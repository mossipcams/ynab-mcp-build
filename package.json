{
  "name": "ynab-mcp-build",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript-first Cloudflare Workers rebuild of ynab-mcp-bridge",
  "scripts": {
    "cf-typegen": "wrangler types",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:mutation": "stryker run",
    "test:mutation:dry": "stryker run --dryRunOnly",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:spec": "tsc --noEmit -p tsconfig.spec.json"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.14",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.9",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "fast-check": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.1"
  }
}
