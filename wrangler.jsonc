{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ynab-mcp-build",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-21",
  "durable_objects": {
    "bindings": [
      {
        "class_name": "OAuthStateDO",
        "name": "OAUTH_STATE"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": ["OAuthStateDO"],
      "tag": "v1"
    }
  ],
  "observability": {
    "enabled": true
  }
}
